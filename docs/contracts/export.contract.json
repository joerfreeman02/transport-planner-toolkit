{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eas.local/tpt/contracts/export/1.0.0",
  "title": "TPT Shared Export Envelope",
  "contractVersion": "1.0.0",
  "type": "object",
  "required": ["platform", "module", "schemaVersion", "generatedAt", "reviewState", "tables"],
  "properties": {
    "platform": { "$ref": "#/$defs/versionIdentity" },
    "module": { "$ref": "#/$defs/versionIdentity" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "reviewState": { "const": "professional-draft" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "tables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["caption", "headers", "rows"],
        "properties": {
          "caption": { "type": "string", "minLength": 1 },
          "headers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "rows": { "type": "array" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "versionIdentity": {
      "type": "object",
      "required": ["id", "version", "build"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "build": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
