{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eas.local/tpt/contracts/module-output/1.0.0",
  "title": "TPT Module Output Envelope",
  "contractVersion": "1.0.0",
  "type": "object",
  "required": ["schemaVersion", "assessmentId", "projectId", "module", "status", "reviewState", "results", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "assessmentId": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "module": {
      "type": "object",
      "required": ["id", "version", "build"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "build": { "type": "string" }
      },
      "additionalProperties": false
    },
    "status": { "enum": ["draft", "complete", "superseded"] },
    "reviewState": { "enum": ["unreviewed", "planner-reviewed"] },
    "results": { "type": "object" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "evidenceReferences": { "type": "array", "items": { "type": "string" } },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
