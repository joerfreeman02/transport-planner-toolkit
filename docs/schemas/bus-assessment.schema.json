{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eas.local/tpt/schemas/bus-assessment/1.1.0",
  "title": "TPT Bus Core Assessment",
  "schemaVersion": "1.1.0",
  "type": "object",
  "required": ["schemaVersion", "assessmentId", "projectName", "site", "search", "stops", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": "1.1.0" },
    "assessmentId": { "type": "string", "minLength": 1 },
    "projectName": { "type": "string", "minLength": 1 },
    "site": { "$ref": "#/$defs/site" },
    "search": { "type": "object", "required": ["radiusM", "maximumStops"], "properties": { "radiusM": { "type": "number", "minimum": 200, "maximum": 3000 }, "maximumStops": { "type": "integer", "minimum": 1, "maximum": 50 }, "provider": { "type": ["string", "null"] } }, "additionalProperties": false },
    "stops": { "type": "array", "items": { "$ref": "#/$defs/stop" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "coordinate": { "type": "object", "required": ["latitude", "longitude", "crs"], "properties": { "latitude": { "type": "number", "minimum": -90, "maximum": 90 }, "longitude": { "type": "number", "minimum": -180, "maximum": 180 }, "crs": { "const": "EPSG:4326" } }, "additionalProperties": false },
    "site": { "type": "object", "required": ["address", "coordinate", "confirmed"], "properties": { "address": { "type": "string", "minLength": 1 }, "coordinate": { "$ref": "#/$defs/coordinate" }, "confirmed": { "const": true } }, "additionalProperties": false },
    "route": { "type": "object", "required": ["distanceM", "durationS", "status", "source"], "properties": { "distanceM": { "type": "number", "minimum": 0 }, "durationS": { "type": "number", "minimum": 0 }, "status": { "enum": ["routed", "estimated"] }, "source": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
    "stop": { "type": "object", "required": ["stopId", "identitySource", "name", "coordinate", "direction", "included", "straightLineM", "walk", "cycle"], "properties": { "stopId": { "type": "string", "minLength": 1 }, "naptanAtcoCode": { "type": ["string", "null"] }, "identitySource": { "enum": ["naptan", "osm-fallback"] }, "name": { "type": "string", "minLength": 1 }, "coordinate": { "$ref": "#/$defs/coordinate" }, "direction": { "type": "string", "minLength": 1 }, "included": { "type": "boolean" }, "straightLineM": { "type": "number", "minimum": 0 }, "walk": { "$ref": "#/$defs/route" }, "cycle": { "$ref": "#/$defs/route" } }, "additionalProperties": false }
  },
  "additionalProperties": false
}

